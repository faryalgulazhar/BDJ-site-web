rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: can read/write own doc, admin can read all
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.token.email == "admin@bdj-karukera.com";
    }

    // Posts: any authenticated user can read/create; only owner or admin can delete
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.authorId ||
         request.auth.token.email == "admin@bdj-karukera.com");
    }

    // Events: anyone can read, only authenticated users can create, admin can update/delete
    match /events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null;
      // Admin has full control; users can update for registration (currentRegistrations/status)
      allow update: if request.auth != null;
      allow delete: if request.auth != null &&
        request.auth.token.email == "admin@bdj-karukera.com";

      // Event Registrations:
      match /registrations/{userId} {
        allow read: if true;
        // User can create their own registration
        allow create: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == "admin@bdj-karukera.com");
        // User can delete their own registration to cancel
        allow delete: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == "admin@bdj-karukera.com");
        // Only admin can update the status
        allow update: if request.auth != null && request.auth.token.email == "admin@bdj-karukera.com";
      }
    }

    // Notifications: admin can create; recipient can read/update (mark as read)
    match /notifications/{notifId} {
      allow create: if request.auth != null &&
        request.auth.token.email == "admin@bdj-karukera.com";
      allow read, update: if request.auth != null &&
        request.auth.uid == resource.data.toUid;
    }
  }
}
