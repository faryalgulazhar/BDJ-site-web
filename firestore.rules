rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: can read/write own doc, admin can read all
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.token.email == "admin@bdj-karukera.com";
    }

    // Posts: any authenticated user can read/create; only owner or admin can delete
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.authorId ||
         request.auth.token.email == "admin@bdj-karukera.com");
    }

    // Sessions: anyone can read, only authenticated users can create, admin can update/delete
    match /sessions/{sessionId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.token.email == "admin@bdj-karukera.com";
    }

    // Notifications: admin can create; recipient can read/update (mark as read)
    match /notifications/{notifId} {
      allow create: if request.auth != null &&
        request.auth.token.email == "admin@bdj-karukera.com";
      allow read, update: if request.auth != null &&
        request.auth.uid == resource.data.toUid;
    }
  }
}
